{
  "entities": {
    "contactMessages": {
      "title": "Contact Messages",
      "description": "Messages sent via the general contact form",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Sender's name" },
        "email": { "type": "string", "format": "email", "description": "Sender's email" },
        "subject": { "type": "string", "description": "Subject of the message" },
        "message": { "type": "string", "description": "Message content" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the message was sent" }
      },
      "required": ["name", "email", "subject", "message", "createdAt"]
    },
    "betaSignups": {
      "title": "Beta Signups",
      "description": "Signups for upcoming applications",
      "type": "object",
      "properties": {
        "appSlug": { "type": "string", "description": "Slug of the app being signed up for" },
        "appTitle": { "type": "string", "description": "Title of the app" },
        "name": { "type": "string", "description": "User's name" },
        "email": { "type": "string", "format": "email", "description": "User's email" },
        "reason": { "type": "string", "description": "Why they are interested" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When they signed up" }
      },
      "required": ["appSlug", "appTitle", "name", "email", "createdAt"]
    },
    "trialSignups": {
      "title": "Trial Signups",
      "description": "Signups for 14-day trials of existing tools",
      "type": "object",
      "properties": {
        "appSlug": { "type": "string", "description": "Slug of the app" },
        "appTitle": { "type": "string", "description": "Title of the app" },
        "name": { "type": "string", "description": "User's name" },
        "email": { "type": "string", "format": "email", "description": "User's email" },
        "businessName": { "type": "string", "description": "Optional business name" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When they signed up" }
      },
      "required": ["appSlug", "appTitle", "name", "email", "createdAt"]
    }
  },
  "firestore": {
    "/contactMessages/{id}": {
      "schema": "contactMessages",
      "description": "General contact form submissions"
    },
    "/betaSignups/{id}": {
      "schema": "betaSignups",
      "description": "Beta tester signups"
    },
    "/trialSignups/{id}": {
      "schema": "trialSignups",
      "description": "14-day trial signups"
    }
  }
}
